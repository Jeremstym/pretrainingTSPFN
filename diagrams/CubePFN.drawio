        <mxCell id="k5SoXD9Zr-yu6RrbrhPo-1783" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;&lt;font style=&quot;font-size: 45px;&quot;&gt;Channel alignement&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="139.62" width="449" x="627.25" y="3632" as="geometry" />
