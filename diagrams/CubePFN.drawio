        <mxCell id="k5SoXD9Zr-yu6RrbrhPo-1784" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 45px;&quot;&gt;$$\mathcal{L}&#39;_{i,k} = \frac{1}{C(C-1)}\sum_{c=1}^C\sum_{c&#39;\neq c}^C \mathrm{CrossEntropy}\left(\frac{\mathbf{s}_i(z_c^{\psi_k},z_{c&#39;}^{\psi_k})}{\tau}, i\right) \quad \forall \psi_k \in \{\psi_1, \psi_2, \psi_3,\psi_4\}$$&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="181" width="1881.5" x="1140" y="3622" as="geometry" />
        </mxCell>
        <mxCell id="k5SoXD9Zr-yu6RrbrhPo-1789" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;&lt;font style=&quot;font-size: 45px;&quot;&gt;Augmentation alignement&lt;/font&gt;&lt;/b&gt;" vertex="1">
