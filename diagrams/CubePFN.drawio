        </mxCell>
        <mxCell id="k5SoXD9Zr-yu6RrbrhPo-1793" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;b style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; text-align: center; background-color: rgb(236, 236, 236);&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 45px;&quot;&gt;$$\mathcal{L} = \frac{1}{N} \sum_{i=1}^B \left(\sum_{k=1}^4 \mathcal{L}&#39;_{i,k} + \sum_{c=1}^C \mathcal{L}&#39;&#39;_{i,c}\right)$$&lt;/font&gt;&lt;/b&gt;" vertex="1">
