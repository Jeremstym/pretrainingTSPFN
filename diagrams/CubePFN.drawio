        <mxCell id="k5SoXD9Zr-yu6RrbrhPo-1790" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 45px;&quot;&gt;$$\mathcal{L}&#39;&#39;_i = \frac{1}{3}\sum_{k=2}^4 \mathrm{CrossEntropy}\left(\frac{\mathbf{s}_i(z_c^{\phi_1},z_{c}^{\phi_k})}{\tau}, i\right) \quad \forall \;c \in[|1,C|]$$&lt;/font&gt;&lt;/b&gt;" vertex="1">
