        <mxCell id="k5SoXD9Zr-yu6RrbrhPo-1790" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 45px;&quot;&gt;$$\mathcal{L}&#39;&#39;_{i,c} = \frac{1}{3}\sum_{k=2}^4 \mathrm{CrossEntropy}\left(\frac{\mathbf{s}_i(z_c^{\psi_1},z_{c}^{\psi_k})}{\tau}, i\right) \quad \forall \;c \in[|1,C|]$$&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="181" width="1397.5" x="1140" y="3994" as="geometry" />
        </mxCell>
        <mxCell id="k5SoXD9Zr-yu6RrbrhPo-1791" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;b style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(236, 236, 236); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 45px;&quot;&gt;$$\text{where } \psi_1 = \mathrm{id},\, \psi_2 = \Delta t,\, \psi_3 = \mathrm{FFT}(t),\, \psi_4 = \mathrm{RandomCropSize}(t)$$&lt;/font&gt;&lt;/b&gt;" vertex="1">
